map $ssl_preread_server_name $sni_name
{
	hostnames;
	{{DOMAIN}}          www;
	{{REALITY_DOMAIN}}  xray;
	{{XHTTP_STREAM_MAP}}
	default              xray;
}

upstream www
{
	server 127.0.0.1:7443;
}

upstream xray
{
	server 127.0.0.1:8443;
}

{{XHTTP_STREAM_UPSTREAM}}

server
{
	proxy_protocol on;
	proxy_connect_timeout 5s;
	proxy_timeout 1h;
	tcp_nodelay on;
	set_real_ip_from unix:;
	listen 443;
	listen [::]:443;
	proxy_pass $sni_name;
	ssl_preread on;
}
